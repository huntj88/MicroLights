######################################################################
# Makefile for BulbChipSTM32C071FBPx
# Auto-discovers source files — no updates needed when adding files.
#
# Usage:
#   make                    # Debug build (default)
#   make BUILD=Release      # Release build (optimized)
#   make LEGACY_PCB_PA7_BUTTON=1  # Build for older PCB with button on PA7
#   make clean              # Remove all build artifacts
#   make compile_commands   # Regenerate compile_commands.json for VS Code
#   make -j$(nproc)         # Parallel build
######################################################################

# --- Project -----------------------------------------------------------
PROJECT  := BulbChipSTM32C071FBPx
BUILD    ?= Debug
BUILD_DIR = build/$(BUILD)
LEGACY_PCB_PA7_BUTTON ?= 0

# --- Toolchain ---------------------------------------------------------
# Auto-detect: use PATH first, fall back to STM32CubeIDE installation
ifeq ($(shell which arm-none-eabi-gcc 2>/dev/null),)
  TOOLCHAIN_DIR := $(shell ls -d /opt/st/stm32cubeide*/plugins/com.st.stm32cube.ide.mcu.externaltools.gnu-tools-for-stm32.*.linux64_*/tools/bin 2>/dev/null | sort -V | tail -1)
  ifneq ($(TOOLCHAIN_DIR),)
    PREFIX = $(TOOLCHAIN_DIR)/arm-none-eabi-
  else
    $(error arm-none-eabi-gcc not found on PATH or in /opt/st/)
  endif
else
  PREFIX = arm-none-eabi-
endif

CC      = $(PREFIX)gcc
AS      = $(PREFIX)gcc -x assembler-with-cpp
LD      = $(PREFIX)gcc
SZ      = $(PREFIX)size
OBJDUMP = $(PREFIX)objdump
OBJCOPY = $(PREFIX)objcopy

# --- MCU ---------------------------------------------------------------
CPU       = -mcpu=cortex-m0plus
FLOAT_ABI = -mfloat-abi=soft
MCU       = $(CPU) -mthumb $(FLOAT_ABI)

# --- Linker script -----------------------------------------------------
LDSCRIPT = STM32C071FBPX_FLASH.ld

# --- Defines -----------------------------------------------------------
C_DEFS = \
  -DUSE_HAL_DRIVER \
  -DSTM32C071xx

ifeq ($(BUILD),Debug)
  C_DEFS += -DDEBUG
endif

ifeq ($(LEGACY_PCB_PA7_BUTTON),1)
  C_DEFS += -DMICROLIGHT_LEGACY_PCB_BUTTON_PA7
endif

# --- Include paths -----------------------------------------------------
C_INCLUDES = \
  -ICore/Inc \
  -Ilibs/tinyusb/src \
  -Ilibs/lwjson/lwjson/src/include \
  -IDrivers/STM32C0xx_HAL_Driver/Inc \
  -IDrivers/STM32C0xx_HAL_Driver/Inc/Legacy \
  -IDrivers/CMSIS/Device/ST/STM32C0xx/Include \
  -IDrivers/CMSIS/Include \
  -Ilibs/tinyexpr

# --- Auto-discover sources ---------------------------------------------
# Application + HAL + BSP  (recursive)
C_SOURCES  = $(shell find Core/Src -name '*.c')
C_SOURCES += $(shell find Drivers/STM32C0xx_HAL_Driver/Src -name '*.c')

# TinyUSB  (recursive — unused portable drivers compile to nothing)
C_SOURCES += $(shell find libs/tinyusb/src -name '*.c')

# lwJSON   (only the library source, not tests/examples)
C_SOURCES += $(shell find libs/lwjson/lwjson/src/lwjson -name '*.c')

# tinyexpr (only the library, not examples/benchmarks)
C_SOURCES += libs/tinyexpr/tinyexpr.c

# Assembly
ASM_SOURCES = $(shell find Core/Startup -name '*.s')

# --- Compiler flags ----------------------------------------------------
COMMON_FLAGS = $(MCU) $(C_DEFS) $(C_INCLUDES) \
  -ffunction-sections -fdata-sections -Wall \
  -fstack-usage -fcyclomatic-complexity \
  --specs=nano.specs

ifeq ($(BUILD),Debug)
  OPT  = -O0
  DBG  = -g3
else
  OPT  = -Os
  DBG  = -g0
endif

CFLAGS  = $(COMMON_FLAGS) -std=gnu11 $(OPT) $(DBG) -MMD -MP
ASFLAGS = $(MCU) $(DBG) --specs=nano.specs -MMD -MP

# --- Linker flags ------------------------------------------------------
LDFLAGS = $(MCU) \
  -T$(LDSCRIPT) \
  --specs=nosys.specs --specs=nano.specs \
  -Wl,-Map=$(BUILD_DIR)/$(PROJECT).map \
  -Wl,--gc-sections \
  -static \
  -Wl,--start-group -lc -lm -Wl,--end-group

# --- Object files ------------------------------------------------------
# Mirror the source tree inside BUILD_DIR
C_OBJS   = $(addprefix $(BUILD_DIR)/, $(C_SOURCES:.c=.o))
ASM_OBJS = $(addprefix $(BUILD_DIR)/, $(ASM_SOURCES:.s=.o))
OBJECTS  = $(C_OBJS) $(ASM_OBJS)

# Dependency files generated by -MMD
DEPS = $(OBJECTS:.o=.d)

# --- Targets -----------------------------------------------------------
TARGET_ELF  = $(BUILD_DIR)/$(PROJECT).elf
TARGET_BIN  = $(BUILD_DIR)/$(PROJECT).bin
TARGET_HEX  = $(BUILD_DIR)/$(PROJECT).hex
TARGET_LIST = $(BUILD_DIR)/$(PROJECT).list

.PHONY: all clean size compile_commands

all: $(TARGET_ELF) $(TARGET_BIN) $(TARGET_HEX) $(TARGET_LIST) size compile_commands

# Link
$(TARGET_ELF): $(OBJECTS) $(LDSCRIPT)
	@echo "[LD]  $@"
	@$(LD) $(OBJECTS) $(LDFLAGS) -o $@

# Binary / Hex
$(TARGET_BIN): $(TARGET_ELF)
	@echo "[BIN] $@"
	@$(OBJCOPY) -O binary $< $@

$(TARGET_HEX): $(TARGET_ELF)
	@echo "[HEX] $@"
	@$(OBJCOPY) -O ihex $< $@

# Listing
$(TARGET_LIST): $(TARGET_ELF)
	@echo "[LST] $@"
	@$(OBJDUMP) -h -S $< > $@

# Size
size: $(TARGET_ELF)
	@$(SZ) $<

# Compile C
$(BUILD_DIR)/%.o: %.c
	@mkdir -p $(dir $@)
	@echo "[CC]  $<"
	@$(CC) $(CFLAGS) -c $< -o $@

# Assemble
$(BUILD_DIR)/%.o: %.s
	@mkdir -p $(dir $@)
	@echo "[AS]  $<"
	@$(AS) $(ASFLAGS) -c $< -o $@

# Clean
clean:
	rm -rf build

# Generate compile_commands.json for VS Code IntelliSense
# Auto-runs with every build; can also run standalone: make compile_commands
COMPDB = compile_commands.json
define make_compdb_entry
{ "directory": "$(CURDIR)", "file": "$(1)", "command": "$(CC) $(CFLAGS) -c $(1)" }
endef

compile_commands: $(COMPDB)
$(COMPDB): Makefile $(C_SOURCES)
	@echo '[GEN] $@'
	@echo '[' > $@
	@$(foreach src,$(C_SOURCES),echo '$(call make_compdb_entry,$(src)),' >> $@ ;)
	@sed -i '$$ s/,$$//' $@
	@echo ']' >> $@

# Pull in auto-generated dependencies
-include $(DEPS)
